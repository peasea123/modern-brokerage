# Neon Postgres database connection string
# Create a free database at https://neon.tech
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Vercel Blob storage (for PDF hosting)
# Automatically set when you add Vercel Blob from the Vercel dashboard
BLOB_READ_WRITE_TOKEN=

# PDF URL in Vercel Blob (set after uploading via admin dashboard)
PDF_BLOB_URL=

# Stripe (wire in later)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=

# Admin password for /admin dashboard
ADMIN_PASSWORD=change-me-in-production

# Site URL (update for production)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
